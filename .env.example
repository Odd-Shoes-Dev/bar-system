# Neon Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# ImageKit (image uploads)
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id
IMAGEKIT_APP_FOLDER=bar-system

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Your Bar Name
# Root domain for multi-tenant subdomain routing (e.g. yourbrand.com)
NEXT_PUBLIC_ROOT_DOMAIN=yourdomain.com

# SMS via ESMS Africa
ESMS_API_KEY=your-esms-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=notifications@yourdomain.com

# Mobile Money (not yet integrated — recording only)
MTN_MOMO_API_KEY=demo
AIRTEL_MONEY_API_KEY=demo
